# Copy this file to .env.deploy and fill in your values.
# .env.deploy is gitignored — this template is safe to commit.

# ── Site ──────────────────────────────────────────────────────────────────
# Your public domain (without https://)
SITE_DOMAIN=atelier.re95.org

# nginx web root for deploy.sh (defaults to /var/www/<SITE_DOMAIN>)
# NGINX_WEB_ROOT=/var/www/atelier.re95.org

# Cloudflare Worker name for IPFS deploys (default: atelier-ipfs)
# WORKER_NAME=atelier-ipfs

# ── Pinata ────────────────────────────────────────────────────────────────
# JWT token for uploading to Pinata IPFS.
# Get from: app.pinata.cloud → Developers → API Keys → New Key (Admin)
PINATA_JWT=xxxxx

# ── Cloudflare ────────────────────────────────────────────────────────────
# Account ID — Cloudflare dashboard → any page URL contains it, or:
#   curl -s "https://api.cloudflare.com/client/v4/zones/<CF_ZONE_ID>" \
#        -H "Authorization: Bearer <CF_API_TOKEN>" | python3 -c \
#        "import json,sys; print(json.load(sys.stdin)['result']['account']['id'])"
CF_ACCOUNT_ID=xxxxx

# Zone ID — Cloudflare dashboard → select domain → Overview → right panel
CF_ZONE_ID=xxxxx

# API token — create at: dash.cloudflare.com/profile/api-tokens → Create Token
# Required permissions (for deploy-ipfs.sh):
#   Account → Workers Scripts → Edit   (to deploy the IPFS proxy Worker)
#   Zone    → Workers Routes  → Edit   (to add/remove the Worker route)
#   Zone    → Cache Purge              (to invalidate CDN cache)
CF_API_TOKEN=xxxxx
